Host *
    ServerAliveInterval 120
    ServerAliveCountMax 60
    TCPKeepAlive yes
    AddKeysToAgent yes

# Adobe GitHub (default — most clones are Adobe org repos)
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_adobe
    IdentitiesOnly yes

# Personal GitHub (use alias "github-personal" when cloning personal repos)
Host github-personal
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_personal
    IdentitiesOnly yes

# Adobe internal GitHub
Host git.corp.adobe.com
    HostName git.corp.adobe.com
    User git
    IdentityFile ~/.ssh/id_corp
    IdentitiesOnly yes
